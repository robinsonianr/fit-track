meta {
  name: Upload PFP
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}:8080/api/v1/members/:memberId/profile-image
  body: multipartForm
  auth: bearer
}

params:path {
  memberId: 1
}

auth:bearer {
  token: {{authToken}}
}

body:multipart-form {
  file: @file(C:\Users\ianrr\Postman\files\pfp_test.jpg)
}
