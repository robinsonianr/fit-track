meta {
  name: Refresh Token
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}:8080/api/v1/auth/refresh
  body: json
  auth: inherit
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  bru.setEnvVar("bearerToken", res.getBody().accessToken)
}

settings {
  encodeUrl: true
  timeout: 0
}
